{
	"extends": "@tsconfig/node24/tsconfig.json",
	"compilerOptions": {
		"composite": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
		"types": [
			"node"
		],
		"allowImportingTsExtensions": true,
		"allowJs": true,
		"emitDeclarationOnly": true
	},
	"include": [
		"src/**/*.ts"
	],
	"exclude": [
		"src/**/*.test.ts",
		"src/**/*.spec.ts",
		"src/**/*.bench.ts"
	]
}
