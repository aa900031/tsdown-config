{
	"extends": "@tsconfig/node24/tsconfig.json",
	"compilerOptions": {
		"composite": false,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
		"types": [
			"node"
		],
		"allowImportingTsExtensions": true,
		"allowJs": true,
		"declaration": false,
		"noEmit": true
	},
	"include": [
		"eslint.config.ts",
		"tsdown.config.ts",
		"vitest.config.ts"
	]
}
